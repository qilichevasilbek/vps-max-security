# === VPS Max Security — DOCKER-USER chain ===
# Generated by vps-max-security. DO NOT EDIT by hand between the BEGIN/END
# markers; re-run `sudo vps-max-security --only firewall` to regenerate.
#
# Why this exists: Docker's DNAT rules run in nat PREROUTING *before*
# filter INPUT, so UFW's "default deny incoming" does NOT protect any
# container published with `-p 0.0.0.0:PORT:PORT`. The DOCKER-USER chain
# is invoked first from FORWARD, survives dockerd restarts, and is the
# only chain we can safely own.
#
# Variables substituted at install time:
#   ${PUBLIC_TCP_PORTS}              — comma-separated, e.g. "80,443"
#   ${LIVEKIT_ENABLED}               — "true" / "false"
#   ${LIVEKIT_UDP_RANGE_START}       — e.g. "50000"
#   ${LIVEKIT_UDP_RANGE_END}         — e.g. "50100"

*filter
:DOCKER-USER - [0:0]

# 1. Always allow established/related return traffic
-A DOCKER-USER -m conntrack --ctstate RELATED,ESTABLISHED -j RETURN

# 2. Drop clearly invalid packets
-A DOCKER-USER -m conntrack --ctstate INVALID -j DROP

# 3. Loopback and Docker bridge subnets — inter-container + host loopback
-A DOCKER-USER -i lo -j RETURN
-A DOCKER-USER -s 172.16.0.0/12 -j RETURN
-A DOCKER-USER -s 10.0.0.0/8    -j RETURN
-A DOCKER-USER -s 192.168.0.0/16 -j RETURN

# 4. Public TCP services (HTTP/HTTPS etc.) — ${PUBLIC_TCP_PORTS}
-A DOCKER-USER -p tcp -m multiport --dports ${PUBLIC_TCP_PORTS} -j RETURN

# 5. LiveKit WebRTC (only if enabled)
# LIVEKIT_ENABLED=${LIVEKIT_ENABLED}
${LIVEKIT_RULES}

# 6. SYN flood mitigation for HTTP/HTTPS
-A DOCKER-USER -p tcp --syn -m multiport --dports ${PUBLIC_TCP_PORTS} \
   -m hashlimit --hashlimit-name http-syn --hashlimit-mode srcip \
   --hashlimit-above 50/sec --hashlimit-burst 100 -j DROP

# 7. Per-IP concurrent connection cap
-A DOCKER-USER -p tcp --syn -m connlimit --connlimit-above 100 --connlimit-mask 32 -j DROP

# 8. Default DROP — everything else destined for containers is blocked
-A DOCKER-USER -j DROP

COMMIT
